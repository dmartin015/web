---
---
<div id="snake-overlay" class="snake-overlay">
  <div class="snake-modal">
    <div class="snake-header">
      <h2>SNAKE MINIGAME</h2>
      <button id="close-snake" class="btn-pixel">CLOSE</button>
    </div>
    <div class="snake-score-board">SCORE: <span id="snake-score">0</span></div>
    <div class="canvas-wrapper">
      <canvas id="snake-game" width="400" height="400"></canvas>
    </div>
    <div class="snake-hints">Use Arrow keys to move</div>
  </div>
</div>

<style>
.snake-overlay {
  display: none;
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.9);
  z-index: 9999;
  justify-content: center; align-items: center;
  flex-direction: column;
}
.snake-overlay.active { display: flex; }
.snake-modal {
  background: #111; border: 2px solid var(--yellow);
  padding: 1rem; border-radius: 8px; box-shadow: 0 0 30px rgba(255,230,0,0.5);
}
.snake-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;
}
.snake-header h2 { margin: 0; font-size: 1.2rem; color: var(--yellow); text-shadow: 2px 2px #000; }
.canvas-wrapper { border: 2px solid #333; }
canvas { background: #000; display: block; }
.snake-score-board { margin-bottom: 0.5rem; font-size: 1rem; color: #fff; }
.snake-hints { margin-top: 1rem; font-size: 0.6rem; color: #aaa; text-align:center; }
#close-snake { background: transparent; color: var(--pink); border-color: var(--pink); }
#close-snake:hover { background: var(--pink); color: #000; }
</style>

<script>
  let konamiCode = ["ArrowUp", "ArrowUp", "ArrowDown", "ArrowDown", "ArrowLeft", "ArrowRight", "ArrowLeft", "ArrowRight", "b", "a"];
  let konamiIndex = 0;

  document.addEventListener('keydown', (e) => {
    let key = e.key;
    if (key === konamiCode[konamiIndex] || key.toLowerCase() === konamiCode[konamiIndex].toLowerCase()) {
      konamiIndex++;
      if (konamiIndex === konamiCode.length) {
        initSnakeGame();
        konamiIndex = 0;
      }
    } else {
      konamiIndex = 0;
    }
  });

  const overlay = document.getElementById('snake-overlay');
  const btnClose = document.getElementById('close-snake');
  const canvas = document.getElementById('snake-game') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  const scoreEl = document.getElementById('snake-score');
  
  let snake, food, dx, dy, score, gameInterval;

  btnClose?.addEventListener('click', () => {
    overlay?.classList.remove('active');
    clearInterval(gameInterval);
  });

  function initSnakeGame() {
    if(!overlay || !ctx) return;
    overlay.classList.add('active');
    
    // Play power-up sound if available from script.js
    if(typeof window.playPowerUpSound === 'function') window.playPowerUpSound();

    snake = [{x: 200, y: 200}, {x: 190, y: 200}, {x: 180, y: 200}];
    food = spawnFood();
    dx = 10;
    dy = 0;
    score = 0;
    if(scoreEl) scoreEl.textContent = '0';
    if(gameInterval) clearInterval(gameInterval);
    gameInterval = setInterval(gameLoop, 100);
  }

  function spawnFood() {
    return {
      x: Math.floor(Math.random() * 40) * 10,
      y: Math.floor(Math.random() * 40) * 10
    };
  }

  function gameLoop() {
    const head = {x: snake[0].x + dx, y: snake[0].y + dy};
    
    // Walls
    if(head.x < 0 || head.x >= 400 || head.y < 0 || head.y >= 400 || collision(head, snake)) {
      clearInterval(gameInterval);
      if(typeof window.playGameOverSound === 'function') window.playGameOverSound();
      alert('GAME OVER! PUNTUACIÓN: ' + score);
      return;
    }

    snake.unshift(head);

    // Food
    if(head.x === food.x && head.y === food.y) {
      score += 10;
      if(scoreEl) scoreEl.textContent = score.toString();
      if(typeof window.playSelectSound === 'function') window.playSelectSound();
      food = spawnFood();
    } else {
      snake.pop();
    }

    draw();
  }

  function collision(head, array) {
    for(let i=0; i < array.length; i++){
      if(head.x === array[i].x && head.y === array[i].y) return true;
    }
    return false;
  }

  function draw() {
    if(!ctx || !canvas) return;
    ctx.clearRect(0,0,canvas.width,canvas.height);
    
    ctx.fillStyle = '#ff2d78';
    ctx.fillRect(food.x, food.y, 10, 10);
    
    ctx.fillStyle = '#00f5ff';
    snake.forEach((part, index) => {
      ctx.fillRect(part.x, part.y, 10, 10);
      ctx.strokeStyle = '#000';
      ctx.strokeRect(part.x, part.y, 10, 10);
    });
  }

  document.addEventListener('keydown', (e) => {
    if (!overlay?.classList.contains('active')) return;
    if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) e.preventDefault();
    if(e.key === 'ArrowUp' && dy === 0) { dx = 0; dy = -10; }
    if(e.key === 'ArrowDown' && dy === 0) { dx = 0; dy = 10; }
    if(e.key === 'ArrowLeft' && dx === 0) { dx = -10; dy = 0; }
    if(e.key === 'ArrowRight' && dx === 0) { dx = 10; dy = 0; }
  });
</script>
